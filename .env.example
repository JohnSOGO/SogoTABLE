# Copy to .env (gitignored) or run: node scripts/serve-bug-manager.mjs --save <passcode>
# The bug-manager reads this so you never re-type the Sogo superuser passcode.
# The bug-report API is a PUBLIC Cloudflare endpoint gated by this passcode — keep it secret.
SOGOTABLE_SUPERUSER_PASSCODE=your-sogo-superuser-passcode-here
