{
  "name": "sogotable",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "scripts": {
    "deploy:brain": "npx wrangler deploy --config wrangler.toml",
    "stamp": "node scripts/stamp-revision.mjs",
    "test": "npm run test:worker",
    "test:worker": "node --test workers/tests/*.test.js",
    "hooks": "git config core.hooksPath scripts/git-hooks",
    "bench:bots": "node scripts/bench-ten-thousand-bots.mjs",
    "bugreports": "node scripts/export-bug-reports.mjs",
    "bugreports:ui": "node scripts/serve-bug-manager.mjs",
    "bugreports:manage": "node scripts/manage-bug-reports.mjs",
    "bugreports:clear": "node scripts/clear-bug-reports.mjs"
  },
  "devDependencies": {
    "playwright": "^1.61.0",
    "wrangler": "^4.0.0"
  }
}
